# Consilium environment — copy to .env and fill in. NEVER commit a real .env.
# Use fresh throwaway keys funded with a little Base Sepolia ETH + test USDC.

# --- Chains ---
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org
# 84532 = Base Sepolia (core dev); 8453 = Base mainnet (1Shot relayer track run)
CHAIN_ID=84532

# --- Test USDC on Base Sepolia ---
# Confirm the CURRENT Base Sepolia USDC test token from https://faucet.circle.com at build time.
# Do not trust a memorized address.
USDC_ADDRESS=

# --- Watched-wallet market question: "Will W's USDC balance exceed T by deadline D?" ---
WATCHED_WALLET=
# Threshold in whole USDC (6-decimals applied in code), e.g. 1000
THRESHOLD_USDC=
# Unix timestamp (seconds) for the market deadline D
DEADLINE_UNIX=

# --- Keys (fresh throwaway keys) ---
DEPLOYER_PRIVATE_KEY=
FUND_MANAGER_PRIVATE_KEY=
BULL_PRIVATE_KEY=
BEAR_PRIVATE_KEY=
# research agent's payTo / smart account signer
RESEARCH_PRIVATE_KEY=

# --- Venice (https://venice.ai/settings/api) ---
VENICE_API_KEY=
VENICE_BASE_URL=https://api.venice.ai/api/v1

# --- 1Shot public relayer (no signup needed) ---
ONESHOT_RELAYER_URL=https://relayer.1shotapi.com/relayers
# public https URL (ngrok/cloudflared) where 1Shot POSTs webhook events
WEBHOOK_PUBLIC_URL=
# local port the webhook server listens on
WEBHOOK_PORT=8787

# --- x402 ---
# testnet facilitator
X402_FACILITATOR_URL=https://x402.org/facilitator

# --- Deployed contract (written by Deploy.s.sol into deployments/<chainId>.json; mirror here if convenient) ---
MARKET_ADDRESS=
