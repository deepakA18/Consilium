# Consilium environment — copy to .env and fill in. NEVER commit a real .env.
# Use fresh throwaway keys funded with a little Base Sepolia ETH + test USDC.

# --- Chains ---
# PRIVATE, server-side only. Put your keyed provider URL (e.g. QuickNode) here. NEVER expose
# this to the browser and NEVER give it a NEXT_PUBLIC_ alias — server code reads it via
# getServerRpcUrl(), which throws if called client-side.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# PUBLIC, browser-safe (no API key). Client viem clients use this; safe in the network tab.
BASE_SEPOLIA_PUBLIC_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org
BASE_MAINNET_PUBLIC_RPC_URL=https://mainnet.base.org
# 84532 = Base Sepolia (core dev); 8453 = Base mainnet (1Shot relayer track run)
CHAIN_ID=84532

# --- Test USDC on Base Sepolia ---
# Circle test USDC on Base Sepolia (confirmed from Circle's faucet token list).
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# --- Watched-wallet market question: "Will W's USDC balance exceed T by deadline D?" ---
WATCHED_WALLET=
# Threshold in whole USDC (6-decimals applied in code), e.g. 1000
THRESHOLD_USDC=
# Unix timestamp (seconds) for the market deadline D
DEADLINE_UNIX=

# --- Keys (fresh throwaway keys) ---
DEPLOYER_PRIVATE_KEY=
FUND_MANAGER_PRIVATE_KEY=
BULL_PRIVATE_KEY=
BEAR_PRIVATE_KEY=
# research agent's payTo / smart account signer
RESEARCH_PRIVATE_KEY=

# --- Reasoning LLM (free / cheap, NOT track-scored). Any OpenAI-compatible endpoint. ---
LLM_PROVIDER=groq                    # groq | openai-compatible — agent reasoning only
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=                         # free Groq key (console.groq.com), or any OpenAI-compatible key
LLM_MODEL=llama-3.3-70b-versatile    # verify a current free model id at build time

# --- Free public RPC for the sold data product (research agent's balance read) ---
DATA_RPC_URL=https://sepolia.base.org   # free public endpoint; may equal BASE_SEPOLIA_PUBLIC_RPC_URL

# --- 1Shot public relayer (no signup needed) ---
ONESHOT_RELAYER_URL=https://relayer.1shotapi.com/relayers
# public https URL (ngrok/cloudflared) where 1Shot POSTs webhook events
WEBHOOK_PUBLIC_URL=
# local port the webhook server listens on
WEBHOOK_PORT=8787

# --- x402 (ERC-7710 settlement via MetaMask facilitator, not x402.org) ---
# Base Sepolia. Mainnet variant: https://tx-sentinel-base-mainnet.api.cx.metamask.io/platform/v2/x402
X402_FACILITATOR_URL=https://tx-sentinel-base-sepolia.api.cx.metamask.io/platform/v2/x402

# --- Deployed contract (written by Deploy.s.sol into deployments/<chainId>.json; mirror here if convenient) ---
MARKET_ADDRESS=
