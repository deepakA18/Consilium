{
  "name": "@consilium/agents",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit",
    "reasoning:smoke": "bun --env-file=../../.env run src/smoke/reasoning.ts",
    "signals:smoke": "bun --env-file=../../.env run src/smoke/signals.ts",
    "feed:smoke": "bun --env-file=../../.env run src/smoke/feed.ts",
    "delegation:smoke": "bun --env-file=../../.env run src/smoke/delegation.ts",
    "x402:smoke": "bun --env-file=../../.env run src/smoke/x402.ts",
    "keys:status": "bun --env-file=../../.env run src/smoke/keys.ts",
    "accounts:upgrade": "bun --env-file=../../.env run src/smoke/upgrade-accounts.ts",
    "oneshot:smoke": "bun --env-file=../../.env run src/smoke/oneshot.ts",
    "relay:stake": "bun --env-file=../../.env run src/smoke/relay-stake.ts",
