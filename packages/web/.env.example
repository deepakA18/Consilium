# Web (Vercel) — PUBLIC env vars only (browser-exposed; never put secrets here).

# The deployed event hub's public URL (the always-on round runner: SSE stream, /round/run,
# /grant/*, /oracle/*). Point this at your Railway/Render/Fly hub. No trailing slash.
NEXT_PUBLIC_EVENTS_URL=https://your-hub.up.railway.app

# WalletConnect Cloud project id — enables the WalletConnect modal in RainbowKit.
# Injected wallets (MetaMask, Rainbow, Coinbase extension) work without it; set it for WC support.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
